APP_NAME="Legal WhatsApp Assistant"
APP_ENV=local
OFFICE_NAME="TNA advocacia"
LOCAL_TIMEZONE=America/Maceio
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/legal_assistant
ANTHROPIC_API_KEY=your_claude_api_key
CLAUDE_MODEL=claude-sonnet-4-6
DEFAULT_ORGANIZATION_ID=1
AI_TEMPERATURE=0.2
AUTO_REPLY_ENABLED=true
FOLLOW_UP_ENABLED=true
FOLLOW_UP_DELAY_HOURS=1
CRM_SESSION_SECRET=tn-crm-local-secret
CRM_SELF_REGISTRATION_ENABLED=true
CRM_ADMIN_EMAIL=atendimento@example.com
CRM_ADMIN_PASSWORD=admin123
CRM_SEED_DEMO_USERS=true
META_GRAPH_API_VERSION=v23.0
META_WHATSAPP_VERIFY_TOKEN=choose_a_strong_verify_token
META_WHATSAPP_ACCESS_TOKEN=your_meta_system_user_access_token
META_WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
META_SEND_HANDOFF_ACK=true
EVOLUTION_ENABLED=true
EVOLUTION_API_URL=http://127.0.0.1:8080
EVOLUTION_API_KEY=choose_a_strong_local_key
EVOLUTION_INSTANCE_NAME=escritorio
EVOLUTION_SEND_HANDOFF_ACK=true
